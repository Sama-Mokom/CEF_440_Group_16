# Copy this file to .env and fill in your real values.
# Never commit your actual .env file to version control.

# MongoDB Atlas connection string, e.g.:
# mongodb+srv://<username>:<password>@<cluster>.mongodb.net/NetInsight?retryWrites=true&w=majority
MONGODB_URI=

# Port the server listens on (Render sets this automatically, default 5000 for local dev)
PORT=5000
